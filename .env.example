# Copy this file to .env and fill in your values.
# Generate a secure JWT secret with: openssl rand -hex 32

# --- Required ---
GROQ_API_KEY=your_groq_api_key_here
APIFY_API_TOKEN=your_apify_api_token_here
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Optional ---
# Token expiry in hours (default: 24)
JWT_EXPIRE_HOURS=24

# Comma-separated list of allowed CORS origins for production.
# Defaults to localhost dev ports when unset.
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Groq model overrides
GROQ_INSIGHTS_MODEL=llama-3.3-70b-versatile
